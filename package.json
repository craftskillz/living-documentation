{
  "name": "living-documentation",
  "version": "7.26.0",
  "description": "A CLI tool that serves a local Markdown documentation viewer",
  "main": "dist/src/server.js",
  "bin": {
    "living-documentation": "dist/bin/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && ts-node scripts/copy-assets.ts && chmod +x dist/bin/cli.js",
    "dev": "nodemon --watch src --watch bin --ext ts,html --exec 'ts-node bin/cli.ts'",
    "start": "node dist/bin/cli.js",
    "test": "npm run test:e2e",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "rm -rf coverage && npm run build && mkdir -p coverage/tmp && COVERAGE=1 NODE_V8_COVERAGE=coverage/tmp playwright test && c8 report",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "documentation",
    "markdown",
    "viewer",
    "cli"
  ],
  "author": "Youssef MEDAGHRI-ALAOUI",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/craftskillz/living-documentation.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "archiver": "7.0.1",
    "commander": "12.1.0",
    "express": "5.2.1",
    "marked": "12.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "c8": "^11.0.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
