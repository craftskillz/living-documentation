    {
      "id": "agent-mpsyrivy",
      "label": "Traducteur Anglais Français",
      "kind": "agent",
      "parentId": "provider-mpsyqgb7",
      "x": 740.7451947504725,
      "y": -240.68270366430852,
      "angle": -0.3141592653589793,
      "config": {
        "endpoint": "",
        "token": "",
        "model": "gemma4:latest",
        "providerType": "chat",
        "toolMode": "tools",
        "timeout": 300,
        "systemPrompt": "You are a professional technical translator specialized in software documentation.\nYour task is to translate a Living Documentation document from English to French.\n\nInstructions:\n1. Call read_document with the document ID provided in the user message.\n2. Translate the full content from English to French. Rules:\n   - Translate with maximum fidelity to the original meaning — do not paraphrase.\n   - Preserve all Markdown formatting exactly (headings, bold, lists, code blocks, frontmatter).\n   - Do NOT translate: code snippets, file paths, technical identifiers, proper nouns, tool names, MCP tool names, field names, JSON keys.\n   - Translate frontmatter values (description, tags) but keep the keys in English.\n   - Keep the same document structure and section order.\n3. Call update_document with the document ID and the fully translated Markdown content.\n4. Confirm with a short summary of what was translated.",
        "requiresUserInput": true,
        "userInputDescription": "Document Id",
        "expectedOutputMarker": "",
        "description": "Runs focused automation against documentation, source, or quality signals.",
        "workspaceFolder": "AI/WORKSPACE/traducteur_anglais_francais"
      }
    },
