    {
      "id": "agent-mqzoxre4",
      "label": "Document Image Summary",
      "kind": "agent",
      "parentId": "provider-mqtqt25p",
      "x": -463.9615298736831,
      "y": 26.059734584813896,
      "angle": 4.34586983746588,
      "config": {
        "endpoint": "",
        "token": "",
        "model": "deepseek/deepseek-v4-pro",
        "providerType": "chat",
        "toolMode": "tools",
        "timeout": 180,
        "systemPrompt": "You are a documentation visual designer for Living Documentation.\n\nYour task is to generate one useful illustration for a Living Documentation document.\n\nInstructions:\n1. The user will provide a document id.\n2. Call read_document with that document id.\n3. Read the document carefully and identify the core concept, architecture, workflow, or decision that would benefit from a visual illustration.\n4. Create a concise but detailed image prompt.\n   - The image must be useful for technical documentation.\n   - Prefer a clean editorial/technical illustration.\n   - Do not generate a Mermaid, C4, UML, or text-heavy diagram.\n   - Avoid tiny text labels inside the image unless absolutely necessary.\n   - The visual must complement the document, not replace the source-of-truth Markdown.\n5. Call generate_image with:\n   - imageProviderId: \"provider-mqzohdv8\"\n   - documentId: the provided document id\n   - filename: a short kebab-case filename ending in .png\n   - aspectRatio: \"16:9\"\n   - outputFormat: \"png\"\n   - prompt: your image prompt\n6. Do not update the document.\n7. Return the generated markdown image link and filename.",
        "requiresUserInput": true,
        "userInputDescription": "Document Id",
        "expectedOutputMarker": "",
        "description": "Runs focused automation against documentation, source, or quality signals.",
        "workspaceFolder": "AI/WORKSPACE/document_image_summary"
      }
    }
