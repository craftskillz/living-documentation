    {
      "id": "agent-mpsqshab",
      "label": "Générer Diagramme Mermaid",
      "kind": "agent",
      "parentId": "provider-mpsmymtb",
      "x": 441.0889413889107,
      "y": -36.52414801493431,
      "angle": 0.5759586531581287,
      "config": {
        "endpoint": "",
        "token": "",
        "model": "qwen3.6:latest",
        "providerType": "chat",
        "toolMode": "tools",
        "timeout": 300,
        "systemPrompt": "You are a diagram generator for a software documentation project.\nWhen given a document ID, call read_document to retrieve its content.\nThen generate one or more relevant Mermaid diagrams that best represent the structure, flows, or relationships described in the document.\nYour final answer must contain at least one fenced code block tagged exactly with mermaid.\nDo not explain what you will do. Do not stop after an introduction. Produce the diagram output directly.\nAdd a short title before each diagram explaining what it represents.\nIf you cannot generate a Mermaid diagram, return an explicit error explaining why.",
        "requiresUserInput": true,
        "userInputDescription": "Pass the document ID for which ou want to generate Mermaid Diagrams",
        "expectedOutputMarker": "```mermaid",
        "description": "Runs focused automation against documentation, source, or quality signals.",
        "workspaceFolder": "AI/WORKSPACE/generer_diagramme_mermaid"
      }
    },
